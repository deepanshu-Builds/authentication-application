



<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font-sans); }

  .page {
    min-height: 100vh;
    background: #0d0d0d;
    color: #e8e6e1;
    padding: 0;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    border-bottom: 1px solid #1e1e1e;
    background: #0d0d0d;
  }

  .logo {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #8B1A1A;
    font-family: var(--font-mono);
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logout-btn {
    font-size: 13px;
    color: #666;
    background: none;
    border: 1px solid #2a2a2a;
    padding: 6px 14px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font-sans);
  }
  .logout-btn:hover { color: #e8e6e1; border-color: #444; }

  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 40px 24px 60px;
  }

  .profile-header {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    margin-bottom: 40px;
  }

  .avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3d0000, #8B1A1A);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 500;
    color: #f5c6c6;
    letter-spacing: -1px;
    border: 2px solid #2a0a0a;
  }

  .online-dot {
    width: 14px;
    height: 14px;
    background: #3ecf6f;
    border-radius: 50%;
    position: absolute;
    bottom: 4px;
    right: 4px;
    border: 2px solid #0d0d0d;
  }

  .profile-info { flex: 1; padding-top: 4px; }

  .name-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .name {
    font-size: 22px;
    font-weight: 500;
    color: #f0eee8;
  }

  .badge {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 3px 8px;
    border-radius: 4px;
    background: #1e0808;
    color: #8B1A1A;
    border: 1px solid #3d0000;
    letter-spacing: 0.04em;
  }

  .username {
    font-size: 14px;
    color: #555;
    font-family: var(--font-mono);
    margin-bottom: 10px;
  }

  .bio {
    font-size: 14px;
    color: #888;
    line-height: 1.6;
    margin-bottom: 14px;
    max-width: 480px;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #555;
  }

  .meta-item i { font-size: 14px; color: #444; }

  .divider {
    height: 1px;
    background: #1a1a1a;
    margin: 32px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 36px;
  }

  .stat-card {
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 10px;
    padding: 16px;
    text-align: center;
    transition: border-color 0.15s;
    cursor: default;
  }
  .stat-card:hover { border-color: #3d0000; }

  .stat-number {
    font-size: 22px;
    font-weight: 500;
    color: #e8e6e1;
    font-family: var(--font-mono);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-title {
    font-size: 13px;
    font-weight: 500;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #1a1a1a;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 36px;
  }

  .project-card {
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 10px;
    padding: 18px;
    transition: border-color 0.15s;
    cursor: pointer;
  }
  .project-card:hover { border-color: #3d0000; }

  .project-name {
    font-size: 14px;
    font-weight: 500;
    color: #8B1A1A;
    font-family: var(--font-mono);
    margin-bottom: 6px;
  }

  .project-desc {
    font-size: 13px;
    color: #555;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .project-footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .lang-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lang-label { font-size: 12px; color: #555; }

  .skills-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-tag {
    font-size: 12px;
    font-family: var(--font-mono);
    padding: 5px 12px;
    border-radius: 6px;
    background: #111;
    border: 1px solid #1e1e1e;
    color: #666;
    transition: all 0.15s;
    cursor: default;
  }
  .skill-tag:hover { border-color: #8B1A1A; color: #c44; }

  .edit-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #555;
    background: none;
    border: 1px solid #2a2a2a;
    padding: 7px 16px;
    border-radius: 7px;
    cursor: pointer;
    margin-top: 32px;
    transition: all 0.15s;
    font-family: var(--font-sans);
  }
  .edit-btn:hover { color: #e8e6e1; border-color: #8B1A1A; }

  .token-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: #3a3a3a;
    background: #0d0d0d;
    border: 1px solid #1a1a1a;
    padding: 4px 10px;
    border-radius: 4px;
  }

  @media (max-width: 560px) {
    .profile-header { flex-direction: column; gap: 16px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="page">
  <nav class="topbar">
    <span class="logo">{"deepanshu-builds"}</span>

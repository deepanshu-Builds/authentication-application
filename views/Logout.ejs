<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout</title>
    <style>
        *{
            padding: 0;
            margin: 0;
            box-sizing: border-box;
        }
        
        .parent{
            height: 100vh;
            width: 100%;
            background-color: rgb(20, 20, 20);
            display: flex;
            justify-content: center;
            align-items: center;
        }
      
        .child{
            background-color:rgb(189, 189, 189) ;
            height: 400px;
            display: flex;
            flex-direction: column;
            justify-content: space-evenly;
            align-items: center;
            border-radius: 20px;
            
          
        }
        .image{
            display: flex;
            justify-content: center;
            height: 50px;
            border-radius: 50%;
            

        }
        img{
            border-radius: 50%;
        }
        h2{
            margin: 10px;
            margin-top: 20px;
            margin-bottom: 20px;
           font-family: cursive;
           font-weight: bold;
          
           
           
        }
        .your{
           margin-top: -1px;
            text-align: center;
            color: rgb(66, 64, 64);
            font-weight: bold;

            margin-bottom: 10px;
        }
        
        button{
            width: 300px;
            padding: 5px;
            margin: 10px;
            color: rgb(59, 58, 57);
            font-family: cursive;
            font-weight: bold;
           
            color: #dbeafe; /* light blue */
   
     background-color: #0433b3;
    border: none;
    border-radius: 5px;
    cursor: pointer;

        }
        button:hover{
            
             background-color: #1d4ed8;
             border: 1px solid black;
             box-shadow: 2px 2px 2px black;

        }
        .data:hover{
            cursor: pointer;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="parent">
        <div class="child">
            <div class="image" >
            <img src="https://img.magnific.com/premium-vector/green-checkmark-inside-orange-circle-affirmation-confirmation_1163725-4151.jpg?semt=ais_hybrid&w=740&q=80" alt=" Image not found">
            </div>
            <h2> YOU LOGGED OUT SUCCESSFULLY </h2>
            <p class="your">Your session has been ended safely.See you next time!</p>
            <button onclick="window.location.href='/' ">Log back in</button>
            <button onclick="window.location.href='/' ">Go to home</button>
               
            <p class="data" >Your data is safe and secure.</p>
        </div>
    </div>
   
</body>
</html>